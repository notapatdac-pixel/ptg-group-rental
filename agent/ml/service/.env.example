# Copy this to .env and fill in real values.
# The service uses the SERVICE ROLE key so it can bypass RLS on ml_* tables
# (those tables have deny-all policies — only the service role can write).

SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_SERVICE_KEY=YOUR-SERVICE-ROLE-KEY

# Optional — override the inference target month (YYYY-MM).
# If unset, the service uses (latest_month_in_data + 1).
# FORECAST_PERIOD=2024-07

# Optional — comma-separated station display_ids to score for matching.
# If unset, scores all stations vs all retailer_profiles.
# MATCHING_STATION_IDS=STN-001,STN-002,STN-003,STN-004,STN-005,STN-018
