# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ─────────────────────────────────────────────────────────────────
# Dashboard → Project Settings → Data API (URL) and API Keys (keys).
# These two are public (used in the browser) — safe to expose; RLS protects data.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — bypasses RLS. SERVER-SIDE ONLY. Never prefix with
# NEXT_PUBLIC_ and never commit the real value.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Google Gemini ────────────────────────────────────────────────────────────
# Get from https://aistudio.google.com/apikey . Server-side only; NEVER prefix
# with NEXT_PUBLIC_.
GEMINI_API_KEY=your-gemini-api-key-here

# ── Python ML service (agent/ml/service) ─────────────────────────────────────
# Base URL of the FastAPI ML service. Used by /api/ml/run and /api/cron/ml-run.
# Local default is http://localhost:8000; set to your deployed host in prod.
ML_SERVICE_URL=http://localhost:8000

# ── Cron secret ──────────────────────────────────────────────────────────────
# A random secret YOU invent; guards /api/cron/ml-run (sent as
# `Authorization: Bearer <CRON_SECRET>`). Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=your-random-cron-secret-here
